---
// Set PUBLIC_FORMSPREE_FORM_ID in .env; create a form at formspree.io and set notification email there (not in code).
const formspreeFormId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID || '';
const formspreeAction = formspreeFormId ? `https://formspree.io/f/${formspreeFormId}` : '';
---
<div class="grid md:grid-cols-2 gap-14">
  <div>
    <h2 class="text-[1.75rem] font-semibold tracking-tight text-foreground mb-3">Start the conversation</h2>
    <p class="text-slate text-[0.9375rem] mb-8 leading-relaxed">Tell us about your plans. We will respond within 24 hours.</p>
    <div class="space-y-4">
      <p class="text-[0.6875rem] font-medium tracking-[0.1em] text-steel uppercase">What happens next</p>
      <ol class="space-y-3 text-slate text-[0.9375rem] leading-relaxed">
        <li class="flex gap-3"><span class="font-medium text-foreground shrink-0">1.</span> 20-minute intro call</li>
        <li class="flex gap-3"><span class="font-medium text-foreground shrink-0">2.</span> We share a 7-day launch plan and cost model</li>
        <li class="flex gap-3"><span class="font-medium text-foreground shrink-0">3.</span> If there is a fit, we start a 30-day pilot</li>
      </ol>
    </div>
  </div>
  <div>
    <form id="contact-form" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="contact-name" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Name <span class="text-destructive">*</span></label>
          <input type="text" id="contact-name" name="name" required class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" />
        </div>
        <div>
          <label for="contact-company" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Company <span class="text-destructive">*</span></label>
          <input type="text" id="contact-company" name="company" required class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" />
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label for="contact-email" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Email <span class="text-destructive">*</span></label>
          <input type="email" id="contact-email" name="email" required class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" />
        </div>
        <div>
          <label for="contact-role" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Role</label>
          <input type="text" id="contact-role" name="role" class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" />
        </div>
      </div>
      <div>
        <label for="contact-building" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">What are you building? <span class="text-destructive">*</span></label>
        <select id="contact-building" name="building" required class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary">
          <option value="">Select</option>
          <option value="new-site">New Romania site</option>
          <option value="existing-team">Existing Romania team</option>
          <option value="both">Both</option>
        </select>
      </div>
      <div>
        <label for="contact-timeline" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Desired timeline</label>
        <select id="contact-timeline" name="timeline" class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary">
          <option value="">Select</option>
          <option value="0-2">0–2 months</option>
          <option value="3-6">3–6 months</option>
          <option value="6+">6+ months</option>
        </select>
      </div>
      <div>
        <label for="contact-message" class="block text-[0.8125rem] font-medium text-foreground mb-1.5">Message</label>
        <textarea id="contact-message" name="message" rows="4" class="w-full px-3.5 py-2.5 text-[0.9375rem] bg-surface border border-divider rounded-md focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary resize-y"></textarea>
      </div>
      <button type="submit" class="w-full inline-flex items-center justify-center gap-2 py-3 bg-primary text-on-primary text-[0.875rem] font-medium rounded-md hover:opacity-95 transition-opacity focus:outline-none focus:ring-1 focus:ring-offset-2 focus:ring-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
        Request plan
      </button>
    </form>
  </div>
</div>

<div id="contact-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 px-5 py-2.5 bg-primary text-on-primary rounded-md text-[0.8125rem] font-medium hidden z-50 shadow-sm" role="status" aria-live="polite">
  Request received. We will be in touch within 24 hours.
</div>

<script define:vars={{ formspreeAction }}>
  const form = document.getElementById('contact-form');
  const toast = document.getElementById('contact-toast');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    if (formspreeAction) {
      try {
        const res = await fetch(formspreeAction, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('Submit failed');
      } catch {
        if (toast) {
          toast.textContent = 'Something went wrong. Please try again.';
          toast.classList.remove('hidden');
          setTimeout(() => {
            toast.textContent = 'Request received. We will be in touch within 24 hours.';
            toast.classList.add('hidden');
          }, 5000);
        }
        return;
      }
    }

    if (toast) {
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 5000);
    }
    form.reset();
  });
</script>
