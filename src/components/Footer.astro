---
import { PHONE_NUMBER } from '../lib/constants';
---
<footer class="bg-surface text-foreground py-14 px-6 lg:px-8 border-t border-divider">
  <div class="max-w-6xl mx-auto">
    <p class="font-semibold text-[0.9375rem] tracking-tight mb-6">BMP : Build. Manage. Perform.</p>
    <nav class="flex flex-wrap gap-8 text-[0.8125rem] font-medium tracking-wide mb-6">
      <a href={`tel:${PHONE_NUMBER}`} class="opacity-90 hover:opacity-100 transition-opacity">{PHONE_NUMBER}</a>
      <a href="#" class="opacity-90 hover:opacity-100 transition-opacity">Privacy Policy</a>
      <a href="#" class="opacity-90 hover:opacity-100 transition-opacity">Imprint / Legal</a>
    </nav>
    <div class="border-t border-white/15 pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[0.75rem] opacity-80 tracking-wide">
      <span class="inline-flex items-center gap-2">
        <svg class="w-3.5 h-3.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        All client references anonymized. Details under NDA.
      </span>
      <span>© 2026 BMP. All rights reserved.</span>
    </div>
  </div>
</footer>
