---
import { PHONE_NUMBER } from '../lib/constants';
---
<section class="min-h-screen flex items-center px-6 lg:px-8 pt-20">
  <div class="max-w-4xl w-full mx-auto">
    <p class="text-[0.6875rem] font-medium tracking-[0.2em] text-steel uppercase mb-8">
      Build-Operate-Transfer and Executive Leadership
    </p>
    <h1 class="text-[2.25rem] lg:text-[2.75rem] font-semibold tracking-tight text-foreground mb-2 leading-[1.15]">
      BMP: Build. Manage. Perform.
    </h1>
    <p class="text-xl lg:text-2xl text-slate font-medium mb-6">
      Romania Hub Launchpad
    </p>
    <p class="text-base text-slate mb-1 font-medium">
      1. Managing Director as a Service
    </p>
    <p class="text-base text-slate mb-8 font-medium">
      2. Build → Operate → Transfer (BOT)
    </p>
    <p class="text-slate text-[0.9375rem] leading-relaxed mb-10 max-w-2xl">
      We build and operate Romania delivery hubs with executive governance—powered by AI-assisted operations.
    </p>
    <ul class="space-y-4 mb-12 text-slate text-[0.9375rem] leading-relaxed">
      <li class="flex items-start gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-foreground mt-2 shrink-0" aria-hidden="true"></span>
        <span>8-week launch: hiring pipeline, setup, operating cadence</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-foreground mt-2 shrink-0" aria-hidden="true"></span>
        <span>Executive governance: KPIs, risk and decision logs, escalation control</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-foreground mt-2 shrink-0" aria-hidden="true"></span>
        <span>AI-enabled operations: faster recruiting, clearer reporting, lower overhead</span>
      </li>
    </ul>
    <div class="flex flex-col sm:flex-row gap-3 mb-20">
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center justify-center gap-2.5 px-5 py-3 border border-foreground rounded-md text-[0.875rem] font-medium text-foreground hover:bg-foreground hover:text-background transition-colors focus:outline-none focus:ring-1 focus:ring-offset-2 focus:ring-primary"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {PHONE_NUMBER}
      </a>
    </div>
    <div class="pt-6 border-t border-divider flex flex-wrap items-center gap-x-4 gap-y-1 text-steel text-[0.75rem] tracking-wide">
      <span>Delivery</span>
      <span class="text-divider" aria-hidden="true">·</span>
      <span>Operations</span>
      <span class="text-divider" aria-hidden="true">·</span>
      <span>Scaling</span>
      <span class="text-divider" aria-hidden="true">·</span>
      <span>Governance</span>
      <span class="text-divider" aria-hidden="true">·</span>
      <span>AI enablement</span>
    </div>
  </div>
</section>
